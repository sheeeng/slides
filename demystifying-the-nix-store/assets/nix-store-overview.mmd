---
title: "Nix Store: From Expressions to Outputs"
---
graph LR
    %% ── Nix Expressions ──
    subgraph expressions["Nix Expressions"]
        direction TB
        nix1["show-utc-datetime.nix"]
        nix2["flake.nix"]
        nix3["default.nix"]
        note_expr["Human-readable source code<br/>describing <b>what</b> to build"]
    end

    %% ── Instantiate arrow ──
    expressions -- "Instantiate<br/><code>nix-instantiate</code><br/><code>nix eval</code>" --> derivations

    %% ── Nix Store: Derivations ──
    subgraph nixstore["/nix/store"]
        direction TB

        subgraph derivations["Store Derivations"]
            direction TB
            drv1["...gn1360z-show-utc-datetime.drv"]
            drv2["...8s9kxnp-bash-5.3p9.drv"]
            drv3["...093gp61-uutils-coreutils-0.6.0.drv"]
            note_drv["Fully resolved build recipes<br/>with pinned dependencies"]
        end

        %% ── Realise arrow ──
        derivations -- "Realise<br/><code>nix-store --realise</code><br/><code>nix build</code>" --> outputs

        subgraph outputs["Store Path Outputs"]
            direction TB
            out1["...v8h9rcs-show-utc-datetime/"]
            out2["...8s9kxnp-bash-5.3p9/"]
            out3["...093gp61-uutils-coreutils-0.6.0/"]
            note_out["Immutable binaries, libraries,<br/>and directories"]
        end
    end

    %% ── Store path structure annotation ──
    subgraph storepath["Store Path Structure"]
        direction TB
        fmt["<code>/nix/store/[digest]-[name]</code><br/>Example: <code>v4bvnkm0...-cargo-1.92.0</code>"]
        hash_props["Same inputs = same hash<br/>Content-addressed and deterministic"]
    end

    outputs -. "Each output follows<br/>the store path format" .-> storepath

